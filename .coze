[project]
requires = ["nodejs-24", "python-3.12"]

[dev]
build = [
  ["bash", "-c", "cd frontend && pnpm install"],
  ["bash", "-c", "pip3 install -r backend/requirements.txt 2>/dev/null"]
]
run = ["bash", "-c", "cd /workspace/projects/backend && python3 init_db.py && uvicorn app.main:app --host 0.0.0.0 --port 8000 > /app/work/logs/bypass/app.log 2>&1 & cd /workspace/projects/frontend && npx vite --port 5000 --host 0.0.0.0"]

[deploy]
build = [
  ["bash", "-c", "cd frontend && pnpm install"],
  ["bash", "-c", "pip3 install -r backend/requirements.txt 2>/dev/null"],
  ["pnpm", "run", "build"]
]
run = ["bash", "-c", "cd /workspace/projects/backend && python3 init_db.py && uvicorn app.main:app --host 0.0.0.0 --port 8000 > /app/work/logs/bypass/app.log 2>&1 & sleep 2 && node server.mjs"]
