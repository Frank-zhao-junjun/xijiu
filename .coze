[project]
requires = ["nodejs-24", "python-3.12"]

[dev]
build = ["bash", "build.sh"]
run = ["bash", "-c", "cd backend && python3 init_db.py && uvicorn app.main:app --host 0.0.0.0 --port 8000 > /app/work/logs/bypass/app.log 2>&1 & cd frontend && npx vite --port 5000 --host 0.0.0.0"]

[deploy]
build = ["bash", "build.sh"]
run = ["bash", "-c", "cd backend && python3 init_db.py && uvicorn app.main:app --host 0.0.0.0 --port 8000 > /app/work/logs/bypass/app.log 2>&1 & sleep 2 && node server.mjs"]
